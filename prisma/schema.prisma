generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Tenant {
  id          String   @id @default(uuid())
  name        String
  phoneNumber String   @unique
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  parents  Parent[]
  children Child[]
  payments Payment[]

  @@map("tenants")
}

model Parent {
  id        String   @id @default(uuid())
  tenantId  String
  name      String
  phone     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant   Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  children Child[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@map("parents")
}

model Child {
  id        String   @id @default(uuid())
  tenantId  String
  parentId  String
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  parent   Parent    @relation(fields: [parentId], references: [id], onDelete: Cascade)
  payments Payment[]
  balance  Balance?

  @@unique([tenantId, name])
  @@index([tenantId])
  @@index([parentId])
  @@map("children")
}

model Payment {
  id            String        @id @default(uuid())
  tenantId      String
  childId       String
  amount        Decimal       @db.Decimal(10, 2)
  paymentMethod PaymentMethod
  date          DateTime      @default(now())
  notes         String?
  createdAt     DateTime      @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  child  Child  @relation(fields: [childId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([childId])
  @@index([tenantId, date])
  @@map("payments")
}

model Balance {
  id             String   @id @default(uuid())
  childId        String   @unique
  currentBalance Decimal  @default(0) @db.Decimal(10, 2)
  updatedAt      DateTime @updatedAt

  child Child @relation(fields: [childId], references: [id], onDelete: Cascade)

  @@map("balances")
}

enum PaymentMethod {
  CASH
  BIT
  BANK_TRANSFER
  CREDIT_CARD
  CHECK
  OTHER
}
