generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Tenant {
  id          String   @id @default(uuid())
  name        String
  phoneNumber String   @unique
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  families Family[]
  payments Payment[]

  @@map("tenants")
}

model Family {
  id         String   @id @default(uuid())
  tenantId   String
  lastName   String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  tenant         Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  parents        Parent[]
  children       Child[]
  payments       Payment[]
  balance        Balance?
  balanceHistory BalanceHistory[]

  @@unique([tenantId, lastName])
  @@index([tenantId])
  @@map("families")
}

model Parent {
  id          String   @id @default(uuid())
  familyId    String
  firstName   String
  email       String?
  phoneNumber String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  family Family @relation(fields: [familyId], references: [id], onDelete: Cascade)

  @@unique([familyId, firstName])
  @@index([familyId])
  @@map("parents")
}

model Child {
  id         String   @id @default(uuid())
  familyId   String
  firstName  String
  gardenName String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  family Family @relation(fields: [familyId], references: [id], onDelete: Cascade)

  @@unique([familyId, firstName])
  @@index([familyId])
  @@map("children")
}

model Payment {
  id            String        @id @default(uuid())
  tenantId      String
  familyId      String
  amount        Decimal       @db.Decimal(10, 2)
  paymentMethod PaymentMethod
  date          DateTime      @default(now())
  notes         String?
  paidFor       String?       // Can store child name or parent name who made the payment
  createdAt     DateTime      @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  family Family @relation(fields: [familyId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([familyId])
  @@index([tenantId, date])
  @@map("payments")
}

model Balance {
  id             String   @id @default(uuid())
  familyId       String   @unique
  currentBalance Decimal  @default(0) @db.Decimal(10, 2)
  updatedAt      DateTime @updatedAt

  family Family @relation(fields: [familyId], references: [id], onDelete: Cascade)

  @@map("balances")
}

model BalanceHistory {
  id             String              @id @default(uuid())
  familyId       String
  previousBalance Decimal            @db.Decimal(10, 2)
  newBalance     Decimal             @db.Decimal(10, 2)
  changeAmount   Decimal             @db.Decimal(10, 2)
  changeType     BalanceChangeType
  changedBy      String?             // Name of person who made the change
  relatedPaymentId String?           // If related to a payment
  notes          String?
  createdAt      DateTime            @default(now())

  family Family @relation(fields: [familyId], references: [id], onDelete: Cascade)

  @@index([familyId])
  @@index([familyId, createdAt])
  @@map("balance_history")
}

enum BalanceChangeType {
  PAYMENT_RECEIVED  // Balance increased due to payment
  BALANCE_SET       // Balance manually set
  CORRECTION        // Manual correction/adjustment
}

enum PaymentMethod {
  CASH
  BIT
  BANK_TRANSFER
  CREDIT_CARD
  CHECK
  OTHER
}
